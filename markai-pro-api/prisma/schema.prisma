generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum ContentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Platform {
  INSTAGRAM
  LINKEDIN
  FACEBOOK
  TIKTOK
  YOUTUBE
  GOOGLE_ADS
  META_ADS
  EMAIL
  BLOG
  TWITTER
}

enum ContentType {
  BLOG_POST
  SOCIAL_CAPTION
  EMAIL
  EMAIL_SEQUENCE
  VIDEO_SCRIPT
  AD_COPY
  LANDING_PAGE
  HEADLINE_VARIANTS
  SEO_BRIEF
  META_TAGS
  KEYWORDS
  PERSONA
  FUNNEL_MAP
  ANALYTICS_REPORT
  IMAGE_PROMPT
  CTA_VARIANTS
  CAMPAIGN_BUNDLE
  CONTENT_CALENDAR
  REPURPOSED_SET
  COMPETITOR_ANALYSIS
  BRAND_VOICE_PROFILE
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
  CLIENT
}

enum InvoiceStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  name               String
  avatarUrl          String?
  role               String    @default("user")
  plan               Plan      @default(FREE)
  credits            Int       @default(50)
  creditsResetAt     DateTime  @default(now())
  onboardingDone     Boolean   @default(false)
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  passwordResetToken String?
  passwordResetExp   DateTime?
  stripeCustomerId   String?   @unique
  stripeSubId        String?
  timezone           String    @default("UTC")
  preferences        Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  refreshTokens      RefreshToken[]
  brandVoice         BrandVoice?
  workspace          Workspace?
  teamMemberships    TeamMember[]
  content            Content[]
  campaigns          Campaign[]
  calendarItems      CalendarItem[]
  creditLogs         CreditLog[]
  competitorReports  CompetitorReport[]
  usageLogs          UsageLog[]
  invoices           Invoice[]
  notifications      Notification[]

  @@index([email])
  @@index([stripeCustomerId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id])
  logoUrl   String?
  industry  String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients   Client[]
  members   TeamMember[]
  campaigns Campaign[]

  @@index([slug])
}

model TeamMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  role        TeamRole  @default(VIEWER)
  inviteEmail String?
  inviteToken String?   @unique
  accepted    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Client {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  logoUrl      String?
  industry     String?
  website      String?
  brandColor   String?   @default("#6C47FF")
  contactName  String?
  contactEmail String?
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  campaigns     Campaign[]
  content       Content[]
  brandVoice    BrandVoice?
  approvalLinks ApprovalLink[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model BrandVoice {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  clientId        String?  @unique
  client          Client?  @relation(fields: [clientId], references: [id])
  formalCasual    Int      @default(50)
  seriousPlayful  Int      @default(50)
  reservedBold    Int      @default(50)
  traditionalInno Int      @default(50)
  technicalSimple Int      @default(50)
  wordsToUse      String[] @default([])
  wordsToAvoid    String[] @default([])
  voiceProfile    Json?
  sampleContent   String[] @default([])
  systemPrompt    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Content {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  campaignId  String?
  campaign    Campaign?     @relation(fields: [campaignId], references: [id])
  title       String
  type        ContentType
  platform    Platform?
  body        String        @db.Text
  bodyHtml    String?       @db.Text
  metadata    Json?
  status      ContentStatus @default(DRAFT)
  toolUsed    String?
  promptUsed  String?       @db.Text
  modelUsed   String?
  creditsUsed Int           @default(0)
  tokensUsed  Int           @default(0)
  version     Int           @default(1)
  parentId    String?
  parent      Content?      @relation("ContentVersions", fields: [parentId], references: [id])
  versions    Content[]     @relation("ContentVersions")
  scheduledFor DateTime?
  publishedAt  DateTime?
  archivedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  calendarItem  CalendarItem?
  approvalLinks ApprovalLink[]

  @@index([userId])
  @@index([clientId])
  @@index([campaignId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  workspaceId    String?
  workspace      Workspace?     @relation(fields: [workspaceId], references: [id])
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id])
  name           String
  goal           String
  targetAudience String?
  keyMessage     String?        @db.Text
  budget         String?
  platforms      Platform[]
  status         CampaignStatus @default(PLANNING)
  startDate      DateTime?
  endDate        DateTime?
  brief          Json?
  stats          Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  content       Content[]
  calendarItems CalendarItem[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
}

model CalendarItem {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  contentId    String?   @unique
  content      Content?  @relation(fields: [contentId], references: [id])
  title        String
  platform     Platform?
  scheduledFor DateTime
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([scheduledFor])
}

model CompetitorReport {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  competitorUrl     String
  competitorName    String?
  competitorLogo    String?
  messagingAnalysis Json?
  contentStrategy   Json?
  keywordGaps       Json?
  counterStrategy   Json?
  rawAnalysis       String?  @db.Text
  createdAt         DateTime @default(now())

  @@index([userId])
}

model ApprovalLink {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id])
  status      String   @default("pending")
  notes       String?
  expiresAt   DateTime
  viewedAt    DateTime?
  respondedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([clientId])
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  reason    String
  toolUsed  String?
  contentId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Invoice {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  stripeInvoiceId String?       @unique
  amount          Int
  currency        String        @default("usd")
  status          InvoiceStatus
  plan            Plan
  periodStart     DateTime
  periodEnd       DateTime
  pdfUrl          String?
  createdAt       DateTime      @default(now())

  @@index([userId])
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  toolName     String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  model        String?
  latencyMs    Int?
  success      Boolean  @default(true)
  errorCode    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([toolName])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
